# ── EduRAG Environment Configuration ──────────────────────────

# Application
APP_NAME=EduRAG
APP_VERSION=1.0.0
DEBUG=false

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./edurag.db
# DATABASE_URL=postgresql://user:password@localhost:5432/edurag

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Upload
MAX_FILE_SIZE_MB=100

# Models Directory (both models auto-download here)
MODELS_DIR=models

# Embedding Model (auto-downloads on first run)
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
EMBEDDING_BATCH_SIZE=32

# LLM Configuration (Mistral-7B 4-bit quantized — auto-downloads on first run)
LLM_MODEL_REPO=TheBloke/Mistral-7B-Instruct-v0.2-GGUF
LLM_MODEL_FILENAME=mistral-7b-instruct-v0.2.Q4_K_M.gguf
LLM_MODEL_PATH=models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
LLM_CONTEXT_LENGTH=4096
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_GPU_LAYERS=33
LLM_THREADS=6

# FAISS
FAISS_TOP_K=5

# Chunking
CHUNK_MIN_WORDS=400
CHUNK_MAX_WORDS=600
CHUNK_OVERLAP_WORDS=100

# OCR (set if tesseract is not in PATH)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
